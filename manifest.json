{
  "manifest_version": 3,
  "name": "Steam Hider",
  "version": "1.0.0",
  "description": "Adds convenient hide controls to the Steam search page.",
  "permissions": [
    "storage"
  ],
  "options_page": "options.html",
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png",
    "512": "icon-512.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://store.steampowered.com/search*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "steam.hide.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "steam.hide.js"
      ],
      "matches": [
        "https://store.steampowered.com/*"
      ]
    }
  ]
}
