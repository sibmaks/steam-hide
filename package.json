{
  "name": "steam-hide",
  "version": "1.0.0",
  "private": true,
  "description": "Chrome/Vivaldi extension for hiding items on the Steam search page.",
  "scripts": {
    "build": "npm run build:win",
    "build:js": "tsc --project tsconfig.json",
    "build:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-extension.ps1",
    "build:linux": "bash scripts/build-extension.sh"
  },
  "devDependencies": {
    "typescript": "^5.9.2"
  }
}
